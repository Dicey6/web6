# =============================================================================
# FundedFrens Telegram Bot — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# =============================================================================

# ── Telegram ──────────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co

# Service role key — bypasses RLS. NEVER expose to frontend.
# Found in: Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Application ───────────────────────────────────────────────────────────────
# Public URL of the FundedFrens website (used in linking instructions)
APP_URL=https://fundedfrens.com

# ── Logging ───────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
