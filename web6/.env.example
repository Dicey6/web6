# =============================================================================
# FundedFrens — Environment Variables Reference
# =============================================================================
#
# FRONTEND (Vercel) — set in Vercel → Settings → Environment Variables
# BACKEND (Render)  — set in Render → Service → Environment
#
# NEVER commit real secrets to Git.
# =============================================================================

# =============================================================================
# FRONTEND (Vite/React — prefix VITE_ to expose to browser bundle)
# =============================================================================

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key
# Leave empty to use same-origin /api routes:
VITE_API_URL=

# =============================================================================
# BACKEND (Express API server — Render)
# =============================================================================

PORT=8080

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# Helius — format: https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your-helius-api-key

# Solana treasury wallet that receives challenge payments
TREASURY_WALLET=your-sol-wallet-address

# Comma-separated allowed CORS origins
ALLOWED_ORIGINS=https://your-vercel-app.vercel.app,https://fundedfrens.com

# Public URL of the frontend (used for referral links)
APP_URL=https://fundedfrens.com

# =============================================================================
# SUPABASE EDGE FUNCTIONS (set in Supabase Dashboard → Edge Functions → Secrets)
# =============================================================================
# SUPABASE_URL          — auto-injected by Supabase
# SUPABASE_SERVICE_ROLE_KEY — auto-injected by Supabase
# HELIUS_API_KEY        — your Helius API key (without the URL wrapper)
# TREASURY_WALLET       — your SOL wallet address
# APP_URL               — https://fundedfrens.com
