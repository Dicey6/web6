# =============================================================================
# FundedFrens — Environment Variables Reference
# =============================================================================
#
# Copy this file to .env.local for local development.
# In production, set these in your hosting provider's dashboard:
#   - Vercel: Settings → Environment Variables (frontend vars ONLY)
#   - Render: Dashboard → Environment (backend vars ONLY)
#
# NEVER commit real secrets to Git.
# =============================================================================

# =============================================================================
# FRONTEND (Vercel) — prefix VITE_ so Vite exposes them to the browser bundle
# =============================================================================

# Your Supabase project URL — found in Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anonymous/public key — safe to expose in the browser
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional: full URL of your deployed API server (e.g. on Render).
# Leave empty ("") to use same-origin relative paths (/api/...).
# Example: https://fundedfrens-api.onrender.com
VITE_API_URL=

# =============================================================================
# BACKEND (Render / local) — never exposed to the browser
# =============================================================================

# Port the Express server listens on. Render injects this automatically.
PORT=8080

# PostgreSQL connection string — Supabase → Settings → Database → Connection string
# Use the "Transaction pooler" URL for Render (port 6543) to avoid connection limits.
DATABASE_URL=postgresql://postgres:your-password@db.your-project-id.supabase.co:5432/postgres

# Supabase project URL (same as VITE_SUPABASE_URL but without the VITE_ prefix)
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase service role key — NEVER expose to the browser. Used for JWT verification.
# Found in Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Comma-separated list of allowed CORS origins for the API server.
# Must include your Vercel deployment URL.
# Example: https://fundedfrens.vercel.app,https://fundedfrens.com
ALLOWED_ORIGINS=https://your-vercel-app.vercel.app

# Solana treasury wallet address — receives SOL payments
TREASURY_WALLET=your-sol-wallet-address

# Public URL of your frontend app (used to build referral links)
APP_URL=https://fundedfrens.vercel.app
